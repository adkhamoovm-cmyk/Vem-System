  "help": {
    "title": "Yordam markazi",
    "subtitle": "Savollaringizga javob topamiz",
    "description": "Quyidagi bo'limlardan o'zingizga kerakli ma'lumotni toping yoki bevosita menejer bilan bog'laning.",
